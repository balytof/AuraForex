generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String             @id @default(uuid())
  email               String             @unique
  passwordHash        String
  role                String             @default("USER") // "USER" ou "ADMIN"
  
  // Sistema de Afiliação
  referralCode        String?            @unique @default(uuid())
  sponsorId           String?
  sponsor             User?              @relation("Sponsor", fields: [sponsorId], references: [id])
  referrals           User[]             @relation("Sponsor")
  totalBonusEarned    Float              @default(0)
  totalBonusWithdrawn Float              @default(0)
  availableBonus      Float              @default(0)

  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  
  connections         BrokerConnection[]
  licenses            License[]
  requests            PurchaseRequest[]
  bonusesReceived     BonusTransaction[] @relation("BonusReceiver")
  bonusesGenerated    BonusTransaction[] @relation("BonusSource")
  withdrawals         WithdrawalRequest[]
  settings            UserSettings?
  signals             Signal[]
}

model LicensePlan {
  id           String   @id @default(uuid())
  name         String   // "Mensal", "Anual", etc.
  price        Float
  durationDays Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  licenses License[]
  requests PurchaseRequest[]
}

model License {
  id        String   @id @default(uuid())
  userId    String
  planId    String?
  type      String   // "PRO", "VIP" (kept for compatibility)
  status    String   // "ACTIVE", "EXPIRED", "SUSPENDED"
  mtAccount String?  // Conta MetaTrader vinculada
  balance   Float    @default(0)
  equity    Float    @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan LicensePlan? @relation(fields: [planId], references: [id])
}

model Signal {
  id          String   @id @default(uuid())
  userId      String
  pair        String
  direction   String
  entry       Float
  sl          Float
  tp          Float
  lot         Float
  status      String   @default("PENDING") // PENDING, EXECUTED, FAILED
  brokerId    String?  // ID da Ordem no MetaTrader (Ticket)
  executedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PaymentMethod {
  id        String   @id @default(uuid())
  name      String   // "USDT-TRC20", "PIX", "Bank"
  details   String   // Endereço da carteira ou chave
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PurchaseRequest {
  id              String   @id @default(uuid())
  userId          String
  planId          String?
  licenseType     String?
  paymentMethodId String?
  transactionHash String?
  amount          Float
  status          String   @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  isBonusProcessed Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan LicensePlan? @relation(fields: [planId], references: [id])
  bonuses BonusTransaction[]
}

model BrokerConnection {
  id                String   @id @default(uuid())
  userId            String
  brokerName        String   // "OANDA", "Capital.com", "MetaTrader"
  brokerType        String   // "oanda", "capital", "metaapi"
  environment       String   // "demo" ou "live"
  
  // Dados de Conta
  accountId         String
  
  // Credenciais (Encriptadas antes de guardar)
  apiTokenEncrypted String?  // OANDA ou MetaApi Token
  capitalIdentifier String?  // Capital email (encrypted)
  capitalPassword   String?  // Capital pw (encrypted)
  
  // MetaApi
  region            String?  // "vint-hill"
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BonusTransaction {
  id          String   @id @default(uuid())
  receiverId  String
  sourceUserId String
  purchaseId  String?
  amount      Float
  level       Int
  status      String   @default("COMPLETED")
  createdAt   DateTime @default(now())

  receiver    User     @relation("BonusReceiver", fields: [receiverId], references: [id])
  sourceUser  User     @relation("BonusSource", fields: [sourceUserId], references: [id])
  purchase    PurchaseRequest? @relation(fields: [purchaseId], references: [id])
}

model WithdrawalRequest {
  id            String   @id @default(uuid())
  userId        String
  amount        Float
  walletAddress String
  network       String
  status        String   @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  adminNotes    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id])
}

model UserSettings {
  id          String   @id @default(uuid())
  userId      String   @unique
  risk        Float    @default(1.5)
  score       Int      @default(55)
  interval    Int      @default(60)
  activePairs String   @default("EURUSD,GBPUSD,USDJPY,XAUUSD,GBPJPY")
  geminiKey   String?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemSettings {
  id                String   @id @default(uuid())
  geminiApiKey      String?
  geminiApiUrl      String? // Novo campo para o "IP do Gemini"
  metaApiToken      String?
  metaApiAccountId  String?
  apiUrl            String?  @default("http://localhost:3005")
  installationGuide String?  @db.Text
  
  // Redes Sociais
  telegramUrl       String?
  whatsappNumber    String?
  facebookUrl       String?
  instagramUrl      String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
